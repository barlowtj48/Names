# Non-sensitive config (local dev defaults). Copy to names.env and edit as needed.
DOMAIN=localhost
BACKEND_PORT=8104
DATABASE_HOST=names-db
DATABASE_PORT=5432
DATABASE_USERNAME=names
DATABASE_PASSWORD=names
DATABASE_NAME=names

# Production-only — required by stack.yml / Taskfile during deploy.
# Leave blank for local dev (the local docker-compose stack ignores them).
DOCKER_REGISTRY=
DEPLOY_NODE=

# Local-dev admin (production uses Docker secrets)
ADMIN_USERNAME=admin
# bcrypt hash of "admin" — change in production!
ADMIN_PASSWORD_BCRYPT=$2a$12$abcdefghijklmnopqrstuu5tD7nU9YJ8GqYqB9XvCqW8nOq.K3Q3i
ADMIN_JWT_SECRET=dev-jwt-secret-change-me
VOTER_SALT=dev-voter-salt-change-me
